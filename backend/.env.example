# Copy to .env for local dev. Defaults already work with SQLite — no edits needed.

# Local dev (default). For prod, use a Supabase Postgres URL:
#   postgresql+psycopg2://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=sqlite:///./lowballer.db

# Listing must be this far below predicted value to be flagged (0.12 = 12%).
FLAG_THRESHOLD=0.12

# Origins allowed to call the API (the Next.js dev server).
CORS_ORIGINS=http://localhost:3000
